# -------------------------------------------------------
# Klaviyo Oversætter — Konfiguration
# Kopiér denne fil til .env og udfyld dine værdier.
# -------------------------------------------------------

# Adgangskode til web-appen
APP_PASSWORD=vælg-en-stærk-adgangskode

# Flask session secret (generér en tilfældig streng, f.eks.: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=skift-denne-til-noget-tilfældigt

# Anthropic / Claude API nøgle
ANTHROPIC_API_KEY=sk-ant-...

# Klaviyo kilde-konto (den konto dine master-templates ligger i, f.eks. DK)
SOURCE_KLAVIYO_API_KEY=pk_...
SOURCE_LANGUAGE=Danish

# Målkonti — én per land du oversætter til.
# "flag" er valgfrit (unicode emoji).
# Indsæt som ét langt JSON-array (ingen linjeskift inde i værdien).
ACCOUNTS_JSON=[
  {"language": "Swedish",    "country": "SE", "flag": "🇸🇪", "api_key": "pk_..."},
  {"language": "Norwegian",  "country": "NO", "flag": "🇳🇴", "api_key": "pk_..."},
  {"language": "Finnish",    "country": "FI", "flag": "🇫🇮", "api_key": "pk_..."},
  {"language": "German",     "country": "DE", "flag": "🇩🇪", "api_key": "pk_..."},
  {"language": "Dutch",      "country": "NL", "flag": "🇳🇱", "api_key": "pk_..."},
  {"language": "French",     "country": "FR", "flag": "🇫🇷", "api_key": "pk_..."},
  {"language": "English",    "country": "UK", "flag": "🇬🇧", "api_key": "pk_..."},
  {"language": "Spanish",    "country": "ES", "flag": "🇪🇸", "api_key": "pk_..."},
  {"language": "Italian",    "country": "IT", "flag": "🇮🇹", "api_key": "pk_..."},
  {"language": "Polish",     "country": "PL", "flag": "🇵🇱", "api_key": "pk_..."},
  {"language": "Portuguese", "country": "PT", "flag": "🇵🇹", "api_key": "pk_..."}
]
